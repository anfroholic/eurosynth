# .env.example — copy to `.env` and edit. docker-compose auto-loads `.env`.
# These are the design knobs for a wafer.space gf180mcuD shuttle. The defaults
# below are eurosynth's known-good settings; you usually only change SLOT.
#
#   cp .env.example .env

# Physical area on the shuttle reticle. One of: 1x1  0p5x1  1x0p5  0p5x0p5
# eurosynth is pinned to the half slot.
SLOT=1x0p5

# Process design kit family (the foundry's rulebook + cell libraries).
PDK=gf180mcuD

# Where the multi-GB PDK lives on your host. docker-compose bind-mounts this to
# /pdk inside the containers, and `scripts/pdk.sh` downloads into it. Defaults to
# ./pdk inside the repo — point it at an absolute path to share one PDK across
# checkouts.
PDK_ROOT=./pdk

# Standard-cell library. fd_sc_mcu7t5v0 is the default 5V 7-track library.
SCL=gf180mcu_fd_sc_mcu7t5v0

# I/O pad ring library.
PAD=gf180mcu_fd_io

# SRAM macro library. The eurosynth core is SRAM-free; this only selects which
# macros_*.yaml the flow loads (5v -> macros_5v.yaml).
SRAM=gf180mcu_fd_ip_sram

# Override the official LibreLane image tag if you need to reproduce a specific
# signoff. See docker/Dockerfile.harden's note for how to pick a tag.
# LIBRELANE_IMAGE=ghcr.io/librelane/librelane:3.1.0.dev2
